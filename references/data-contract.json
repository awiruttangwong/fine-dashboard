  "date_normalization": {
    "expected_business_period_inference": "2026-06-01 through 2026-06-21",
    "rules": [
      {
        "when": "text matching d/m/yyyy or dd/mm/yyyy",
        "action": "parse day-first",
        "status": "ok_text_dmy"
      },
      {
        "when": "Excel datetime in this workbook where year=2026, day=6, month=1..12",
        "action": "swap month/day to produce June 1..12, 2026",
        "status": "ok_excel_serial_swapped"
      },
      {
        "when": "future Excel datetime does not match workbook-specific swap pattern",
        "action": "keep actual date only after review",
        "status": "ok_excel_serial_as_is"
      },
      {
        "when": "unparseable date",
        "action": "set fine_date null",
        "status": "invalid"
      }
    ]
  },
  "quality_rules": {
    "full_duplicate": "same raw A-I values after trimming",
    "barcode_duplicate": "same nonblank barcode appears on more than one source row",
    "driver_blank": "driver_name is null or empty after trimming",
    "receiver_blank": "transfer_receiver_name is null or empty after trimming",
    "amount_mismatch": "remaining_amount is present and remaining_amount != fine_amount - coalesce(paid_amount, 0)"
  },
  "payment_status_rules": {
    "paid": "paid_amount >= fine_amount and computed remaining <= 0 and no mismatch flag",
    "partial": "paid_amount > 0 and paid_amount < fine_amount",
    "open": "paid_amount is null or 0 and no amount mismatch flag",
    "overpaid": "paid_amount > fine_amount",
    "data_error": "amount mismatch or unexpected negative amount"
  },
